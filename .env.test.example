# Overrides for the optional claude-chat-test instance.
# Copy to .env.test and edit. When this file is present at install time,
# install.sh enables claude-chat-test.service (port 8421) in addition
# to the production claude-chat.service.
#
# Test sender isolation relies on THIS FILE being sourced BEFORE the main
# .env by the systemd unit (later EnvironmentFile entries override earlier
# ones; but the test unit loads .env *first* and .env.test *second* so the
# overrides here win). Anything not set here falls through to .env.
#
# The test instance must share NO filesystem / DB / port / CLAUDE_CWD with
# production. Keep bases disjoint: /home/you/projects-test/ (a sibling of
# your real projects dir), not a subdirectory of CLAUDE_CWD.

CHAT_DB_PATH=claude-chat-test.db
CHAT_HOST=127.0.0.1
CHAT_PORT=8421
CHAT_URL=http://127.0.0.1:8421/sse

# Must be a SIBLING of production CLAUDE_CWD, never a child. A child
# directory shares physical paths with prod workers and breaks isolation.
CLAUDE_CWD=/home/you/projects-test

# Router MCP config for workers spawned by THIS chat-chat instance —
# the .mcp-test.json file points at port 8421 so their `claude --continue`
# talks to the test bus, not the production one.
ROUTER_MCP_CONFIG=__INSTALL_DIR__/.mcp-test.json
