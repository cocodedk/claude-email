# Per-sender overrides for the optional test universe.
#
# Copy to .env.test and edit. When this file is present:
#   - claude-email reads it as a separate namespace (not merged into
#     os.environ) and treats SENDER as the additional authorized sender.
#   - install.sh enables claude-chat-test.service (port 8421) — that
#     systemd unit also reads this file AFTER .env, so the bare-key
#     overrides below reconfigure the test chat-chat without needing
#     any TEST_ prefix.
#
# The whole point: drop file in place, get a second isolated universe
# with its own credentials, DB, project base. NO reuse of prod's secret.

# The authorized email address for this universe. Required. Must differ
# from AUTHORIZED_SENDER in .env.
SENDER=test@example.com

# A DIFFERENT shared secret from prod. If this one leaks, prod is still
# safe. Generate with: `openssl rand -base64 24`.
SHARED_SECRET=replace_with_test_only_secret

# Optional GPG: if set, emails from SENDER must be signed by this key
# (independent of prod's GPG_FINGERPRINT).
GPG_FINGERPRINT=
GPG_HOME=

# MUST be a SIBLING of production CLAUDE_CWD, never a child. A child
# directory shares physical paths with prod workers and breaks isolation.
CLAUDE_CWD=/home/you/projects-test

# Override the chat-chat bus for this universe. The installer uses
# these values to configure claude-chat-test.service.
CHAT_DB_PATH=claude-chat-test.db
CHAT_HOST=127.0.0.1
CHAT_PORT=8421
CHAT_URL=http://127.0.0.1:8421/sse
SERVICE_NAME_CHAT=claude-chat-test.service

# Workers spawned by claude-chat-test talk to port 8421, not 8420.
ROUTER_MCP_CONFIG=__INSTALL_DIR__/.mcp-test.json
