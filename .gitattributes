# Normalize all text files to LF on commit
* text=auto eol=lf

*.py        text eol=lf
*.sh        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.env       text eol=lf
*.service   text eol=lf

*.png       binary
*.jpg       binary
*.pdf       binary
*.zip       binary
