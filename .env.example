# ── Email (IMAP + SMTP) ──
IMAP_HOST=imap.example.com
IMAP_PORT=993
SMTP_HOST=smtp.example.com
SMTP_PORT=465
EMAIL_ADDRESS=claude@example.com
EMAIL_PASSWORD=your_password_here
AUTHORIZED_SENDER=you@example.com
EMAIL_DOMAIN=example.com

# ── Polling & CLI ──
POLL_INTERVAL=30
CLAUDE_TIMEOUT=300
CLAUDE_BIN=claude
CLAUDE_CWD=/home/you/projects
STATE_FILE=processed_ids.json

# Optional model/effort/budget overrides for the claude CLI subprocess.
# Leave blank (or omit) to use the CLI's built-in defaults.
# CLAUDE_MODEL=claude-opus-4-5          # e.g. claude-opus-4-5, claude-sonnet-4-5
# CLAUDE_EFFORT=high                    # low | medium | high | xhigh | max (thinking effort)
# CLAUDE_MAX_BUDGET_USD=1.00            # dollar cap per --print call; only enforced
#                                       # under API-key auth (subscription ignores it).
#                                       # Not applied to interactive (no-instruction) spawns.

# ── YOLO / non-interactive tool approval ──
# Email-driven runs have no TTY, so tool-permission prompts would hang forever.
# Set CLAUDE_YOLO=1 to pass --dangerously-skip-permissions to the claude CLI
# (both for executor commands and spawned chat agents). Security: the email
# layer is already gated by GPG or shared-secret from AUTHORIZED_SENDER, so
# this trusts the sender, not arbitrary input. Leave blank to disable.
CLAUDE_YOLO=1
# Use a dedicated config dir (e.g. a personal account separate from work).
CLAUDE_CONFIG_DIR=/home/you/.claude-personal
# NOTE: do NOT set IS_SANDBOX=1 unless the service actually runs inside a
# sandbox (firejail/bwrap/systemd confinement). Claude treats IS_SANDBOX as
# a hint to restrict filesystem scope, which breaks access to CLAUDE_CWD.

# ── LLM email router (experimental, Phase 2) ──
# When 1, the CLI-fallback claude (the path used when the email doesn't
# match @agent / spawn / status in the subject) receives a system prompt
# describing the chat_enqueue_task MCP tool, so it can enqueue tasks on
# per-project workers in response to natural-language bodies.
# Leave blank to keep today's deterministic keyword-only routing.
LLM_ROUTER=

# ── Per-project worker knobs (Phase 3) ──
# The chat server spawns one worker per canonical project path on demand.
# Each worker pops tasks from the queue and runs them via
# `claude --continue --print <body>` so context is preserved across turns.
WORKER_TASK_TIMEOUT=3600  # seconds for a single claude invocation
WORKER_IDLE_TIMEOUT=300   # seconds of empty queue before worker exits

# ── Logging ──
LOG_FILE=claude-email.log

# ── Chat system ──
CHAT_DB_PATH=claude-chat.db
CHAT_HOST=127.0.0.1
CHAT_PORT=8420
CHAT_URL=http://127.0.0.1:8420/sse

# ── Service names (for restart commands) ──
SERVICE_NAME_EMAIL=claude-email.service
SERVICE_NAME_CHAT=claude-chat.service

# ── Auth (at least one required) ──
SHARED_SECRET=change_this_to_a_strong_secret

# GPG mode (recommended — set fingerprint to enable, leave SHARED_SECRET blank if using GPG)
# Get your fingerprint: gpg --list-keys you@example.com
GPG_FINGERPRINT=
GPG_HOME=
