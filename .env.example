# ── Email (IMAP + SMTP) ──
IMAP_HOST=imap.example.com
IMAP_PORT=993
SMTP_HOST=smtp.example.com
SMTP_PORT=465
EMAIL_ADDRESS=claude@example.com
EMAIL_PASSWORD=your_password_here
AUTHORIZED_SENDER=you@example.com
EMAIL_DOMAIN=example.com

# ── Polling & CLI ──
POLL_INTERVAL=30
CLAUDE_TIMEOUT=300
CLAUDE_BIN=claude
CLAUDE_CWD=/home/you/projects
STATE_FILE=processed_ids.json

# ── Logging ──
LOG_FILE=claude-email.log

# ── Chat system ──
CHAT_DB_PATH=claude-chat.db
CHAT_HOST=127.0.0.1
CHAT_PORT=8420
CHAT_URL=http://127.0.0.1:8420/sse

# ── Service names (for restart commands) ──
SERVICE_NAME_EMAIL=claude-email.service
SERVICE_NAME_CHAT=claude-chat.service

# ── Auth (at least one required) ──
SHARED_SECRET=change_this_to_a_strong_secret

# GPG mode (recommended — set fingerprint to enable, leave SHARED_SECRET blank if using GPG)
# Get your fingerprint: gpg --list-keys you@example.com
GPG_FINGERPRINT=
GPG_HOME=
