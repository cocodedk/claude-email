IMAP_HOST=imap.one.com
IMAP_PORT=993
SMTP_HOST=send.one.com
SMTP_PORT=465
EMAIL_ADDRESS=claude@cocode.dk
EMAIL_PASSWORD=your_password_here
AUTHORIZED_SENDER=bb@cocode.dk
POLL_INTERVAL=30
CLAUDE_TIMEOUT=300
SHARED_SECRET=change_this_to_a_strong_secret

# GPG mode (recommended — set fingerprint to enable, leave SHARED_SECRET blank if using GPG)
# Get your fingerprint: gpg --list-keys bb@cocode.dk
GPG_FINGERPRINT=
GPG_HOME=
